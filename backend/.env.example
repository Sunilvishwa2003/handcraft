# Backend environment variables for local development and production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT auth
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=30d

# Frontend public URL (Vercel or other hosting)
CLIENT_URL=https://your-frontend-url.vercel.app

# Google OAuth (server-only)
# Use the same Web application client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID in frontend/.env.local.
# In Google Cloud Console, add every browser origin you use for this app to
# Authorized JavaScript origins, for example:
# http://localhost:3000
# http://127.0.0.1:3000
# https://your-frontend-url.vercel.app
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Telegram order notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp artisan contact
WHATSAPP_PHONE_NUMBER=919999999999

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server port (Render will override this automatically)
PORT=5001

# Node environment
NODE_ENV=production
